# ---------------------------------------------------------------------------
# Prompt for destructive Rails tasks (despite broad Rails allows)
# ---------------------------------------------------------------------------
prefix_rule(
    pattern=["bundle", "exec", "rails", ["db:drop", "db:purge", "db:reset", "db:truncate_all", "destroy"]],
    decision="prompt",
    justification="Potentially destructive Rails task. Please confirm before running."
)
prefix_rule(
    pattern=["bin/rails", ["db:drop", "db:purge", "db:reset", "db:truncate_all", "destroy"]],
    decision="prompt",
    justification="Potentially destructive Rails task. Please confirm before running."
)
prefix_rule(
    pattern=["mise", "exec", "--", "bundle", "exec", "rails", ["db:drop", "db:purge", "db:reset", "db:truncate_all", "destroy"]],
    decision="prompt",
    justification="Potentially destructive Rails task. Please confirm before running."
)
prefix_rule(
    pattern=["mise", "exec", "--", "bin/rails", ["db:drop", "db:purge", "db:reset", "db:truncate_all", "destroy"]],
    decision="prompt",
    justification="Potentially destructive Rails task. Please confirm before running."
)

# Staging Kamal deploy/lock actions used in this project.
prefix_rule(pattern=["bundle", "exec", "kamal", "deploy", "-d", "staging"], decision="allow")
prefix_rule(pattern=["bundle", "exec", "kamal", "lock", "release", "-d", "staging"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "bundle", "exec", "kamal", "deploy", "-d", "staging"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "bundle", "exec", "kamal", "lock", "release", "-d", "staging"], decision="allow")
prefix_rule(pattern=["mise", "exec", "ruby@4.0.1", "--", "bundle", "exec", "kamal", "deploy", "-d", "staging"], decision="allow")
prefix_rule(pattern=["mise", "exec", "ruby@4.0.1", "--", "bundle", "exec", "kamal", "lock", "release", "-d", "staging"], decision="allow")

# Any explicit production Kamal action requires approval.
prefix_rule(
    pattern=["bundle", "exec", "kamal", "deploy", "-d", "production"],
    decision="prompt",
    justification="Production deploy command detected. Please confirm before running."
)
prefix_rule(
    pattern=["bundle", "exec", "kamal", "lock", "release", "-d", "production"],
    decision="prompt",
    justification="Production deploy command detected. Please confirm before running."
)
prefix_rule(
    pattern=["mise", "exec", "--", "bundle", "exec", "kamal", "deploy", "-d", "production"],
    decision="prompt",
    justification="Production deploy command detected. Please confirm before running."
)
prefix_rule(
    pattern=["mise", "exec", "--", "bundle", "exec", "kamal", "lock", "release", "-d", "production"],
    decision="prompt",
    justification="Production deploy command detected. Please confirm before running."
)
prefix_rule(
    pattern=["mise", "exec", "ruby@4.0.1", "--", "bundle", "exec", "kamal", "deploy", "-d", "production"],
    decision="prompt",
    justification="Production deploy command detected. Please confirm before running."
)
prefix_rule(
    pattern=["mise", "exec", "ruby@4.0.1", "--", "bundle", "exec", "kamal", "lock", "release", "-d", "production"],
    decision="prompt",
    justification="Production deploy command detected. Please confirm before running."
)
