# Project rules for rails-chat.
# Goal: autonomous day-to-day development in this repo without full-access.
# Anything not matched here falls back to approval_policy="untrusted".

# ---------------------------------------------------------------------------
# Local debugging / inspection commands used in this project
# ---------------------------------------------------------------------------
prefix_rule(pattern=["pwd"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["sed"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["nl"], decision="allow")
prefix_rule(pattern=["head"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["awk"], decision="allow")
prefix_rule(pattern=["jq"], decision="allow")
prefix_rule(pattern=["echo"], decision="allow")
prefix_rule(pattern=["printf"], decision="allow")
prefix_rule(pattern=["sleep"], decision="allow")
prefix_rule(pattern=["which"], decision="allow")
prefix_rule(pattern=["realpath"], decision="allow")
prefix_rule(pattern=["strings"], decision="allow")
prefix_rule(pattern=["dig"], decision="allow")
prefix_rule(pattern=["curl"], decision="allow")
prefix_rule(pattern=["mkdir"], decision="allow")
prefix_rule(pattern=["cp"], decision="allow")
prefix_rule(pattern=["mv"], decision="allow")
prefix_rule(pattern=["chmod"], decision="allow")

# ---------------------------------------------------------------------------
# Git workflows used in this project
# ---------------------------------------------------------------------------
prefix_rule(
    pattern=[
        "git",
        [
            "status",
            "diff",
            "log",
            "show",
            "branch",
            "rev-parse",
            "ls-files",
            "add",
            "commit",
            "push",
            "pull",
            "checkout",
            "switch",
            "fetch",
            "merge",
            "rebase",
            "restore",
            "stash",
            "remote",
            "init",
            "clone",
            "rm"
        ]
    ],
    decision="allow"
)

# ---------------------------------------------------------------------------
# Rails / Bundler / Mise workflows
# ---------------------------------------------------------------------------
prefix_rule(pattern=["bundle", "install"], decision="allow")
prefix_rule(
    pattern=["bundle", "exec", ["rspec", "rubocop", "rake", "rails", "brakeman", "bundler-audit"]],
    decision="allow"
)
prefix_rule(pattern=["bin/rspec"], decision="allow")
prefix_rule(pattern=["bin/rubocop"], decision="allow")
prefix_rule(pattern=["bin/rake"], decision="allow")
prefix_rule(pattern=["bin/rails"], decision="allow")
prefix_rule(pattern=["bin/docker-dev"], decision="allow")

prefix_rule(pattern=["mise", "exec", "--", "bundle", "install"], decision="allow")
prefix_rule(
    pattern=[
        "mise",
        "exec",
        "--",
        "bundle",
        "exec",
        ["rspec", "rubocop", "rake", "rails", "brakeman", "bundler-audit"]
    ],
    decision="allow"
)
prefix_rule(pattern=["mise", "exec", "--", "bin/rspec"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "bin/rubocop"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "bin/rake"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "bin/rails"], decision="allow")
prefix_rule(pattern=["mise", "exec", "--", "bin/docker-dev"], decision="allow")

# ---------------------------------------------------------------------------
# Docker commands used in local development/debugging
# ---------------------------------------------------------------------------
prefix_rule(pattern=["docker", "compose"], decision="allow")
prefix_rule(pattern=["docker", "run"], decision="allow")
prefix_rule(pattern=["docker", "rm"], decision="allow")
prefix_rule(pattern=["docker", "ps"], decision="allow")
prefix_rule(pattern=["docker", "logs"], decision="allow")
prefix_rule(pattern=["docker", "build"], decision="allow")

# ---------------------------------------------------------------------------
# Terraform commands: allow bootstrap/staging, prompt production
# ---------------------------------------------------------------------------
prefix_rule(pattern=["terraform", "version"], decision="allow")
prefix_rule(pattern=["terraform", "fmt"], decision="allow")
prefix_rule(pattern=["terraform", "validate"], decision="allow")
prefix_rule(pattern=["terraform", "-chdir=infra/terraform/bootstrap"], decision="allow")
prefix_rule(pattern=["terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/bootstrap"], decision="allow")
prefix_rule(pattern=["terraform", "-chdir=infra/terraform/environments/staging"], decision="allow")
prefix_rule(pattern=["terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/environments/staging"], decision="allow")

# Equivalent terraform invocation via env prefix.
prefix_rule(pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "-chdir=infra/terraform/bootstrap"], decision="allow")
prefix_rule(pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/bootstrap"], decision="allow")
prefix_rule(pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "-chdir=infra/terraform/environments/staging"], decision="allow")
prefix_rule(pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/environments/staging"], decision="allow")
prefix_rule(pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "version"], decision="allow")
prefix_rule(pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "fmt"], decision="allow")
prefix_rule(pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "validate"], decision="allow")
prefix_rule(pattern=["AWS_PROFILE=rails-chat", "terraform", "-chdir=infra/terraform/bootstrap"], decision="allow")
prefix_rule(pattern=["AWS_PROFILE=rails-chat", "terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/bootstrap"], decision="allow")
prefix_rule(pattern=["AWS_PROFILE=rails-chat", "terraform", "-chdir=infra/terraform/environments/staging"], decision="allow")
prefix_rule(pattern=["AWS_PROFILE=rails-chat", "terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/environments/staging"], decision="allow")
prefix_rule(pattern=["AWS_PROFILE=rails-chat", "terraform", "version"], decision="allow")
prefix_rule(pattern=["AWS_PROFILE=rails-chat", "terraform", "fmt"], decision="allow")
prefix_rule(pattern=["AWS_PROFILE=rails-chat", "terraform", "validate"], decision="allow")

prefix_rule(
    pattern=["terraform", "-chdir=infra/terraform/environments/production"],
    decision="prompt",
    justification="Production Terraform command detected. Please confirm before running."
)
prefix_rule(
    pattern=["terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/environments/production"],
    decision="prompt",
    justification="Production Terraform command detected. Please confirm before running."
)
prefix_rule(
    pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "-chdir=infra/terraform/environments/production"],
    decision="prompt",
    justification="Production Terraform command detected. Please confirm before running."
)
prefix_rule(
    pattern=["env", "AWS_PROFILE=rails-chat", "terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/environments/production"],
    decision="prompt",
    justification="Production Terraform command detected. Please confirm before running."
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "terraform", "-chdir=infra/terraform/environments/production"],
    decision="prompt",
    justification="Production Terraform command detected. Please confirm before running."
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "terraform", "-chdir=/Users/marc/Projects/rails-chat/infra/terraform/environments/production"],
    decision="prompt",
    justification="Production Terraform command detected. Please confirm before running."
)
prefix_rule(
    pattern=["cd", "/Users/marc/Projects/rails-chat/infra/terraform/environments/production"],
    decision="prompt",
    justification="Changing into production Terraform directory requires confirmation."
)
prefix_rule(
    pattern=["cd", "infra/terraform/environments/production"],
    decision="prompt",
    justification="Changing into production Terraform directory requires confirmation."
)

