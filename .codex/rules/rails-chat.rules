# Mutating AWS commands: explicit staging allow, production-specific prompts below.
prefix_rule(
    pattern=["aws", "ecr", "delete-repository"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "ecr", "delete-repository"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "ecr", "batch-delete-image"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "ecr", "batch-delete-image"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "autoscaling", "start-instance-refresh"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "autoscaling", "start-instance-refresh"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "secretsmanager", "delete-secret"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "secretsmanager", "delete-secret"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "acm", "request-certificate"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "acm", "request-certificate"],
    decision="allow"
)

# Explicit staging mutations are allowed.
prefix_rule(
    pattern=["aws", "ecr", "delete-repository", "--repository-name", "rails-chat-staging/rails-chat"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "ecr", "delete-repository", "--repository-name", "rails-chat-staging/rails-chat"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "ecr", "batch-delete-image", "--region", "eu-central-1", "--repository-name", "rails-chat-staging/rails-chat"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "ecr", "batch-delete-image", "--region", "eu-central-1", "--repository-name", "rails-chat-staging/rails-chat"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "autoscaling", "start-instance-refresh", "--auto-scaling-group-name", "rails-chat-staging-asg"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "autoscaling", "start-instance-refresh", "--auto-scaling-group-name", "rails-chat-staging-asg"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "secretsmanager", "delete-secret", "--secret-id", "rails-chat-staging/db/password"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "secretsmanager", "delete-secret", "--secret-id", "rails-chat-staging/db/password"],
    decision="allow"
)
prefix_rule(
    pattern=["aws", "acm", "request-certificate", "--domain-name", "chat-staging.schopp3r.de"],
    decision="allow"
)
prefix_rule(
    pattern=["AWS_PROFILE=rails-chat", "aws", "acm", "request-certificate", "--domain-name", "chat-staging.schopp3r.de"],
    decision="allow"
)

