<%= turbo_frame_tag "#{chat_room.messages_dom_id}_form" do %>
  <%= form_with model: [chat_room, chat_message], class: "space-y-3", data: { chat_bot_target: "form" } do |f| %>
    <div>
      <%= f.label :body, "Nachricht", class: "mb-1 block text-xs font-medium uppercase tracking-wide text-slate-600" %>
      <%= f.text_area :body,
        rows: 3,
        placeholder: "Schreibe deine Nachricht...",
        class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring-2",
        data: { chat_bot_target: "body" } %>
      <% if chat_message.errors[:body].any? %>
        <p class="mt-1 text-xs text-rose-600"><%= chat_message.errors[:body].to_sentence %></p>
      <% end %>
    </div>

    <div class="flex justify-end">
      <%= f.submit "Senden",
        class: "rounded-xl bg-cyan-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-500",
        data: { chat_bot_target: "submit" } %>
    </div>
  <% end %>
<% end %>
