<section class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <header class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900">Reset password</h1>
    <p class="mt-1 text-sm text-slate-600">Set a new password for your account.</p>
  </header>

  <%= form_with model: @user, url: password_path(params[:token]), method: :patch, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :password, class: "mb-1 block text-xs font-medium uppercase tracking-wide text-slate-600" %>
      <%= f.password_field :password,
        required: true,
        maxlength: 72,
        autocomplete: "new-password",
        class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring-2" %>
      <% if @user.errors[:password].any? %>
        <p class="mt-1 text-xs text-rose-600"><%= @user.errors[:password].to_sentence %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "mb-1 block text-xs font-medium uppercase tracking-wide text-slate-600" %>
      <%= f.password_field :password_confirmation,
        required: true,
        maxlength: 72,
        autocomplete: "new-password",
        class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring-2" %>
    </div>

    <div class="flex justify-end">
      <%= f.submit "Update password",
        class: "rounded-xl bg-cyan-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-500" %>
    </div>
  <% end %>
</section>
