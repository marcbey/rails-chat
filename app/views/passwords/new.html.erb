<section class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <header class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900">Forgot password</h1>
    <p class="mt-1 text-sm text-slate-600">Enter your email address to receive a reset link.</p>
  </header>

  <%= form_with url: passwords_path, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email_address, "Email", class: "mb-1 block text-xs font-medium uppercase tracking-wide text-slate-600" %>
      <%= f.email_field :email_address,
        required: true,
        autocomplete: "email",
        class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring-2" %>
    </div>

    <div class="flex items-center justify-between gap-3">
      <%= link_to "Back to sign in", new_session_path, class: "text-sm font-medium text-cyan-700 hover:text-cyan-600" %>
      <%= f.submit "Send reset link",
        class: "rounded-xl bg-cyan-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-500" %>
    </div>
  <% end %>
</section>
